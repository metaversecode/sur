<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Results for "' + query + '"' }) %>
</head>
<body>
  <%- include('partials/nav') %>

  <!-- Results page -->
  <main class="page">
    <div class="page-container">

      <!-- Inline search bar -->
      <div class="results-search animate-in">
        <form action="/search" method="GET" class="search-form" id="search-form">
          <div class="search-wrapper search-wrapper-sm">
            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="text" name="q" class="search-input" value="<%= query %>" autocomplete="off" id="search-input">
            <button type="submit" class="search-submit" id="search-submit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </button>
          </div>
        </form>
      </div>

      <!-- Header -->
      <div class="page-header animate-in">
        <% if (error) { %>
          <div class="alert alert-error">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" x2="9" y1="9" y2="15"/>
              <line x1="9" x2="15" y1="9" y2="15"/>
            </svg>
            <%= error %>
          </div>
        <% } %>

        <h1 class="page-title">
          Results for "<span><%= query %></span>"
        </h1>
        <p class="results-count"><%= persons.length %> record<%= persons.length !== 1 ? 's' : '' %> found</p>
      </div>

      <% if (persons.length > 0) { %>
        <div class="cards-grid">
          <% persons.forEach((person, i) => { %>
            <a href="/person/<%= person.id %>" class="person-card" style="animation-delay: <%= i * 0.06 %>s">
              <% if (person.thumbnail) { %>
                <img class="card-image" src="<%= person.thumbnail %>" alt="<%= person.name %>">
              <% } else { %>
                <div class="card-image-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </div>
              <% } %>
              <div class="card-body">
                <h3 class="card-name"><%= person.name %></h3>
                <% if (person.instagramId) { %>
                  <div class="card-insta">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                    </svg>
                    @<%= person.instagramId.replace(/@/g, '') %>
                  </div>
                <% } %>
                <% if (person.photoCount && person.photoCount > 1) { %>
                  <div class="card-photo-count">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                      <circle cx="9" cy="9" r="2"/>
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                    </svg>
                    <%= person.photoCount %> photos
                  </div>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state animate-in">
          <svg class="empty-state-icon" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
            <path d="M8 11h6"/>
          </svg>
          <h3>No results found</h3>
          <p>We couldn't find anyone matching "<%= query %>". Try a different name.</p>
        </div>
      <% } %>

    </div>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
