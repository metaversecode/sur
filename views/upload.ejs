<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Upload Record' }) %>
</head>
<body>
  <%- include('partials/nav') %>

  <!-- Upload form -->
  <main class="page">
    <div class="page-container">

      <div class="page-header animate-in">
        <a href="/" class="page-back" id="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
          Back
        </a>
      </div>

      <div class="upload-section animate-in">
        <div class="upload-card">
          <div class="upload-header">
            <div class="upload-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" x2="12" y1="3" y2="15"/>
              </svg>
            </div>
            <h1 class="upload-title">Upload New Record</h1>
            <p class="upload-subtitle">Add a person's information to the database</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-error">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="15" x2="9" y1="9" y2="15"/>
                <line x1="9" x2="15" y1="9" y2="15"/>
              </svg>
              <%= error %>
            </div>
          <% } %>

          <% if (success) { %>
            <div class="alert alert-success">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
              <%= success %>
            </div>
          <% } %>

          <form action="/upload" method="POST" enctype="multipart/form-data" id="upload-form">
            <!-- Name -->
            <div class="form-group">
              <label class="form-label" for="name-input">Full Name</label>
              <input
                type="text"
                name="name"
                class="form-input"
                placeholder="Enter person's full name"
                id="name-input"
                required
              >
            </div>

            <!-- Instagram ID -->
            <div class="form-group">
              <label class="form-label" for="insta-input">Instagram ID</label>
              <div class="input-icon-wrap">
                <svg class="input-prefix-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                </svg>
                <input
                  type="text"
                  name="instagramId"
                  class="form-input form-input-icon"
                  placeholder="@username"
                  id="insta-input"
                >
              </div>
              <p class="form-hint">Optional — include the @ symbol</p>
            </div>

            <!-- Photos -->
            <div class="form-group">
              <label class="form-label">Photos</label>
              <div class="drop-zone" id="drop-zone">
                <svg class="drop-zone-icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                  <circle cx="9" cy="9" r="2"/>
                  <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                </svg>
                <p class="drop-zone-text">Drop photos here or <strong>click to browse</strong></p>
                <p class="drop-zone-hint">JPG, PNG, WebP • Max 10 photos • 10MB each</p>
                <input
                  type="file"
                  name="photos"
                  id="photo-input"
                  multiple
                  accept="image/jpeg,image/png,image/webp"
                >
              </div>
              <div class="photo-previews" id="photo-previews"></div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-submit" id="submit-btn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" x2="12" y1="3" y2="15"/>
              </svg>
              Upload Record
            </button>
          </form>
        </div>
      </div>

    </div>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>
