<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: person.name }) %>
</head>
<body>
  <%- include('partials/nav') %>

  <!-- Person detail -->
  <main class="page">
    <div class="page-container">

      <div class="page-header animate-in">
        <a href="javascript:history.back()" class="page-back" id="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
          Back
        </a>
      </div>

      <!-- Profile header -->
      <div class="person-profile animate-in">
        <h1 class="person-name"><%= person.name %></h1>

        <% if (person.instagramId) { %>
          <% const handle = person.instagramId.replace(/@/g, ''); %>
          <a href="https://instagram.com/<%= handle %>" target="_blank" rel="noopener noreferrer" class="person-insta" id="insta-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
            @<%= handle %>
            <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7"/>
              <path d="M7 7h10v10"/>
            </svg>
          </a>
        <% } %>
      </div>

      <!-- Photo gallery -->
      <% if (person.photos && person.photos.length > 0) { %>
        <p class="gallery-label animate-in">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <%= person.photos.length %> Photo<%= person.photos.length > 1 ? 's' : '' %>
        </p>
        <div class="photo-gallery">
          <% person.photos.forEach((photo, i) => { %>
            <div class="gallery-item" style="animation-delay: <%= i * 0.06 %>s" data-src="<%= photo %>">
              <img src="<%= photo %>" alt="<%= person.name %> — Photo <%= i + 1 %>">
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state animate-in">
          <svg class="empty-state-icon" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <h3>No photos available</h3>
          <p>This record doesn't have any photos attached yet.</p>
        </div>
      <% } %>

    </div>
  </main>

  <!-- Lightbox overlay -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="Full size photo">
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
